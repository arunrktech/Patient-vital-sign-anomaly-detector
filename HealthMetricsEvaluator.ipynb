import numpy as np

np.random.seed(42)
n = 500

# Normal patients
X_normal = np.column_stack([
    np.random.normal(72,  8,   n),   # heart rate (bpm)
    np.random.normal(120, 10,  n),   # systolic BP (mmHg)
    np.random.normal(98,  1,   n),   # SpO2 (%)
    np.random.normal(37,  0.3, n),   # temperature (Celsius)
])

# Abnormal patients (elevated heart rate, BP, temp, low SpO2)
X_abnormal = np.column_stack([
    np.random.normal(110, 15,  n),
    np.random.normal(160, 20,  n),
    np.random.normal(93,  3,   n),
    np.random.normal(38.5, 0.5, n),
])

# Stack them together
X = np.vstack([X_normal, X_abnormal])
y = np.array([0]*n + [1]*n, dtype=float)  # 0 = normal, 1 = abnormal

# Peek at what we created
print("Dataset shape:", X.shape)
print("First normal patient :", X[0].round(2))
print("First abnormal patient:", X[500].round(2))
print("Label for first patient:", y[0], "  Label for 501st patient:", y[500])


# Compute mean and std from the data
X_mean = X.mean(axis=0)   # one mean per column
X_std  = X.std(axis=0)    # one std per column

# Apply the formula: z = (x - mean) / std
X_norm = (X - X_mean) / X_std

# Check the result
print("Original column means:", X_mean.round(2))
print("Original column stds: ", X_std.round(2))
print()
print("Normalized column means:", X_norm.mean(axis=0).round(4))
print("Normalized column stds: ", X_norm.std(axis=0).round(4))
print()
print("A raw patient record    :", X[0].round(2))
print("The normalized version  :", X_norm[0].round(4))


def sigmoid(z):
    return 1 / (1 + np.exp(-z))

# Test it on a few values to confirm it matches your intuition
test_values = np.array([-6, -2, 0, 2, 6])
results = sigmoid(test_values)

for z, s in zip(test_values, results):
    print(f"sigmoid({z:+d}) = {s:.4f}")\


    # Initialize weights and bias to zero
W = np.zeros(4)   # one weight per feature
b = 0.0

print("Initial weights:", W)
print("Initial bias   :", b)
print()

# Forward pass: compute z for all 1000 patients at once
z = X_norm @ W + b

print("z shape:", z.shape)      # should be (1000,) — one value per patient
print("First 5 z values:", z[:5].round(4))
print()

# Pass z through sigmoid to get probabilities
y_hat = sigmoid(z)

print("First 5 predictions:", y_hat[:5].round(4))
print("Min prediction:", y_hat.min().round(4))
print("Max prediction:", y_hat.max().round(4))


def compute_loss(y_true, y_pred):
    return -np.mean(
        y_true * np.log(y_pred + 1e-9) +
        (1 - y_true) * np.log(1 - y_pred + 1e-9)
    )

# Current loss with all weights = 0 (all predictions = 0.5)
loss = compute_loss(y, y_hat)
print("Loss when predicting 0.5 for everyone:", round(loss, 4))

# Let's see what loss looks like for a perfect model
perfect_preds = y.copy()
perfect_preds[perfect_preds == 0] = 0.001   # near 0 for normal patients
perfect_preds[perfect_preds == 1] = 0.999   # near 1 for abnormal patients
print("Loss for near-perfect predictions    :", round(compute_loss(y, perfect_preds), 4))

# And for a completely wrong model
terrible_preds = 1 - perfect_preds
print("Loss for completely wrong predictions :", round(compute_loss(y, terrible_preds), 4))

# One complete gradient update step
def gradient_step(X, y, W, b, lr=0.1):
    n = len(y)

    # Forward pass
    z = X @ W + b
    y_hat = sigmoid(z)

    # Compute loss
    loss = compute_loss(y, y_hat)

    # Compute gradients
    error = y_hat - y               # how wrong were we, per patient
    dW = X.T @ error / n            # gradient for each weight
    db = np.mean(error)             # gradient for bias

    # Update weights in the opposite direction of gradient
    W_new = W - lr * dW
    b_new = b - lr * db

    return W_new, b_new, loss

# Run just one step and see what changes
W_new, b_new, loss_after = gradient_step(X_norm, y, W, b)

print("Before update:")
print("  weights:", W.round(4))
print("  bias   :", round(b, 4))
print()
print("After one gradient step:")
print("  weights:", W_new.round(4))
print("  bias   :", round(b_new, 4))
print()
print("Loss after one step:", round(loss_after, 4))
print("Loss before        :", 0.6931)
print("Improvement        :", round(0.6931 - loss_after, 6))

# Reset weights to zero before training
W = np.zeros(4)
b = 0.0
lr = 0.1
epochs = 1000

loss_history = []

print("Starting training...\n")

for epoch in range(epochs):

    # Forward pass
    z = X_norm @ W + b
    y_hat = sigmoid(z)

    # Compute loss
    loss = compute_loss(y, y_hat)
    loss_history.append(loss)

    # Compute gradients
    error = y_hat - y
    dW = X_norm.T @ error / len(y)
    db = np.mean(error)

    # Update weights
    W = W - lr * dW
    b = b - lr * db

    # Print progress every 100 epochs
    if epoch % 100 == 0:
        preds = (y_hat >= 0.5).astype(int)
        accuracy = np.mean(preds == y) * 100
        print(f"Epoch {epoch:4d} | loss: {loss:.4f} | accuracy: {accuracy:.1f}%")

print("\nTraining complete.")

import matplotlib.pyplot as plt

# Final predictions
z_final = X_norm @ W + b
y_hat_final = sigmoid(z_final)
final_preds = (y_hat_final >= 0.5).astype(int)
final_accuracy = np.mean(final_preds == y) * 100

print("Final Results")
print("=" * 40)
print(f"Final loss    : {loss_history[-1]:.4f}")
print(f"Final accuracy: {final_accuracy:.1f}%")

print("\nLearned weights (what the model thinks matters):")
feature_names = ["heart rate", "blood pressure", "SpO2", "temperature"]
for name, weight in zip(feature_names, W):
    direction = "abnormal" if weight > 0 else "normal"
    print(f"  {name:16s}: {weight:+.4f}  (pushes toward {direction})")
print(f"  {'bias':16s}: {b:+.4f}")

# Plot how loss dropped during training
plt.figure(figsize=(8, 4))
plt.plot(loss_history, color='#7F77DD', linewidth=1.5)
plt.xlabel("Epoch")
plt.ylabel("Loss")
plt.title("Loss during training")
plt.axhline(y=0.6931, color='#888780', linestyle='--', linewidth=1, label='baseline (random)')
plt.legend()
plt.tight_layout()
plt.show()

# Test on two invented patients
print("\nPredicting on new patients:")
new_patients = np.array([
    [72, 118, 98.5, 36.9],   # clearly normal
    [118, 168, 91,  39.1],   # clearly abnormal
])
new_norm = (new_patients - X_mean) / X_std    # use same mean/std from training
new_probs = sigmoid(new_norm @ W + b)

labels = ["normal", "abnormal"]
for i, prob in enumerate(new_probs):
    pred = "abnormal" if prob >= 0.5 else "normal"
    print(f"  Patient {i+1}: {prob:.1%} probability abnormal → predicted {pred}")
