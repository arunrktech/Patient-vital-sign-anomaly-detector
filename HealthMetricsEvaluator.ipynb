import numpy as np
import pandas as pd
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from openpyxl.utils import get_column_letter

np.random.seed(42)
n = 500

data_normal = np.column_stack([
    np.random.normal(72,   8,   n),
    np.random.normal(120,  10,  n),
    np.random.normal(98,   1,   n),
    np.random.normal(37,   0.3, n),
])
data_abnormal = np.column_stack([
    np.random.normal(110,  15,  n),
    np.random.normal(160,  20,  n),
    np.random.normal(93,   3,   n),
    np.random.normal(38.5, 0.5, n),
])

all_rows = np.vstack([data_normal, data_abnormal])

def make_border():
    s = Side(style='thin', color='D3D1C7')
    return Border(left=s, right=s, top=s, bottom=s)

wb = Workbook()
ws = wb.active
ws.title = 'patient_vitals'

headers    = ['patient_id', 'heart_rate_bpm', 'systolic_bp_mmhg', 'spo2_pct', 'temperature_c']
col_widths = [12, 18, 20, 12, 16]

for col_idx, (header, width) in enumerate(zip(headers, col_widths), start=1):
    cell           = ws.cell(row=1, column=col_idx, value=header)
    cell.font      = Font(name='Arial', bold=True, color='FFFFFF', size=11)
    cell.fill      = PatternFill('solid', start_color='534AB7')
    cell.alignment = Alignment(horizontal='center', vertical='center')
    cell.border    = make_border()
    ws.column_dimensions[get_column_letter(col_idx)].width = width
ws.row_dimensions[1].height = 24

for i in range(n * 2):
    row    = i + 2
    values = [
        f'P{i+1:04d}',
        round(float(all_rows[i, 0]), 1),
        round(float(all_rows[i, 1]), 1),
        round(float(all_rows[i, 2]), 1),
        round(float(all_rows[i, 3]), 2),
    ]
    for col_idx, val in enumerate(values, start=1):
        cell           = ws.cell(row=row, column=col_idx, value=val)
        cell.font      = Font(name='Arial', size=10)
        cell.alignment = Alignment(horizontal='center', vertical='center')
        cell.fill      = PatternFill('solid', start_color='F1EFE8')
        cell.border    = make_border()

ws.freeze_panes = 'A2'
INPUT_PATH = '/content/patient_vitals.xlsx'
wb.save(INPUT_PATH)
print(f'Input file written: {INPUT_PATH}')

df           = pd.read_excel(INPUT_PATH)
feature_cols = ['heart_rate_bpm', 'systolic_bp_mmhg', 'spo2_pct', 'temperature_c']
X            = df[feature_cols].values
y            = np.array([0]*n + [1]*n, dtype=float)

print('Dataset shape:', X.shape)
print('First patient :', X[0].round(2))
print('Patient 501   :', X[500].round(2))
print('Label row 1 / row 501:', y[0], '/', y[500])
